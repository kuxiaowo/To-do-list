{
  "name": "managebac-sync-helper",
  "version": "1.0.0",
  "private": true,
  "description": "Local ManageBac bridge for To-Do List task preview sync.",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "cn.managebac.sync.helper",
    "productName": "nethub.wiki ManageBac 同步辅助程序",
    "protocols": [
      {
        "name": "ManageBac Sync Helper",
        "schemes": [
          "managebac-sync"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "icon.ico",
          "icon.png"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "include": "build/installer.nsh"
    }
  }
}
