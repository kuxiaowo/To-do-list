# Server bind address and port.
# Keep TODO_HOST as 127.0.0.1 when using a reverse proxy such as Caddy or Nginx.
TODO_HOST=127.0.0.1
TODO_PORT=8092

# Optional AI configuration.
# Copy this file to .env and replace the placeholder before enabling AI features.
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=20

# Optional first-run admin bootstrap for deploy-first-run.sh.
# The deploy script imports server.py, so these values can be loaded from .env.
# Set both nickname and password, or leave all admin values commented out.
# TODO_ADMIN_NICKNAME=admin
# TODO_ADMIN_NAME=Administrator
# TODO_ADMIN_PASSWORD=change-this-password

# Optional deploy script service name.
# Note: deploy-first-run.sh reads this in bash before server.py loads .env,
# so set it as an exported shell variable if you need a custom service name:
# TODO_SERVICE_NAME=todo-list.service
